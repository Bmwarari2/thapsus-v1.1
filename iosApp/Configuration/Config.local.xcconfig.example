// Copy this file to Config.local.xcconfig (ignored by git) and fill in real values.
// Only the anon key may live in a mobile build — never the service-role key.
//
// xcconfig parses "//" as a comment marker, so URLs need the SLASH escape.

TEAM_ID = YOUR_APPLE_TEAM_ID
APP_BUNDLE_ID = uk.thapsus.cargo

SLASH = /
SUPABASE_URL = https:$(SLASH)$(SLASH)your-project.supabase.co
SUPABASE_ANON_KEY = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your.anon.key

// Express backend lives on its own Railway service — separate from the
// React webapp host (thapsus.uk). The iOS app talks directly to the API
// service, not via the webapp.
//
// The `/api` suffix matters: Express mounts every route under `/api/...`
// (`app.use('/api/auth', ...)`, etc.), and ThapsusApiClient appends caller
// paths like `/auth/login` to this baseUrl verbatim. Drop the suffix and
// every call lands at the 404 "Route not found" handler.
//
// Use http://localhost:5000/api when running Express locally.
API_BASE_URL = https:$(SLASH)$(SLASH)swiftcargo-production.up.railway.app/api
