// Copy this file to Config.local.xcconfig (ignored by git) and fill in real values.
// Only the anon key may live in a mobile build — never the service-role key.
//
// xcconfig parses "//" as a comment marker, so URLs need the SLASH escape.

TEAM_ID = YOUR_APPLE_TEAM_ID
APP_BUNDLE_ID = uk.thapsus.cargo

SLASH = /
SUPABASE_URL = https:$(SLASH)$(SLASH)your-project.supabase.co
SUPABASE_ANON_KEY = eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your.anon.key

// Express backend (Swiftcargo-main). The webapp at thapsus.uk calls /api/...
// against same-origin, so this is the same host iOS should hit.
// Use http://localhost:5000 when running Express locally.
API_BASE_URL = https:$(SLASH)$(SLASH)www.thapsus.uk
