<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleDisplayName</key>
    <string>Thapsus Cargo</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>1.0.0</string>
    <key>CFBundleVersion</key>
    <string>1</string>

    <!-- Supabase connection — values come from Config.xcconfig at build time. -->
    <key>SUPABASE_URL</key>
    <string>$(SUPABASE_URL)</string>
    <key>SUPABASE_ANON_KEY</key>
    <string>$(SUPABASE_ANON_KEY)</string>

    <!-- Express backend (Swiftcargo-main /api). Set via Config.local.xcconfig. -->
    <key>API_BASE_URL</key>
    <string>$(API_BASE_URL)</string>

    <!-- App schemes we open ourselves (WhatsApp). Required by iOS 9+ for
         canOpenURL/openURL on a non-https scheme. -->
    <key>LSApplicationQueriesSchemes</key>
    <array>
        <string>whatsapp</string>
    </array>

    <!-- Custom URL scheme for deep links: thapsus://pay/<orderId> opens the
         PublicPaymentView for invoice settlement. -->
    <key>CFBundleURLTypes</key>
    <array>
        <dict>
            <key>CFBundleURLName</key>
            <string>uk.thapsus.cargo.pay</string>
            <key>CFBundleURLSchemes</key>
            <array>
                <string>thapsus</string>
            </array>
        </dict>
    </array>

    <key>LSRequiresIPhoneOS</key>
    <true/>
    <key>UIApplicationSceneManifest</key>
    <dict>
        <key>UIApplicationSupportsMultipleScenes</key>
        <false/>
    </dict>
    <!-- Launch screen — matches SplashView 1:1 (BrandCream bg, logo + wordmark).
         Replaces the previous flat-navy UILaunchScreen color which painted a
         dark blue panel during the multi-second cold dyld + Kotlin/Native
         framework load on first launch. -->
    <key>UILaunchStoryboardName</key>
    <string>LaunchScreen</string>
    <key>UISupportedInterfaceOrientations</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
    </array>
    <key>UISupportedInterfaceOrientations~ipad</key>
    <array>
        <string>UIInterfaceOrientationPortrait</string>
        <string>UIInterfaceOrientationPortraitUpsideDown</string>
        <string>UIInterfaceOrientationLandscapeLeft</string>
        <string>UIInterfaceOrientationLandscapeRight</string>
    </array>

    <!-- U.S. encryption export compliance.

         Set to NO under the BIS "uses only Apple-provided / standard
         encryption" exemption. Audited 2026-05-17 for the first App Store
         submission:

           • All HTTPS goes through URLSession / Network.framework — the
             Supabase Swift SDK consumes URLSession; we do NOT bundle
             BoringSSL or any third-party TLS stack on iOS. (The earlier
             plist comment claiming "Supabase HTTPS via BoringSSL" was
             carried over from the Android/JVM side and was incorrect for
             the iOS target.)
           • JWT signature validation uses CryptoKit (Apple-provided).
           • SHA-256 / HMAC over reset-tokens, OTPs, and log-out token
             revocation uses CryptoKit (Apple-provided).
           • The app does NOT implement its own cryptographic algorithms.

         Per the BIS year-letter guidance, an app that uses encryption
         only via the operating system or for HTTPS authentication with
         the app's own back-end servers qualifies for the "mass-market
         exemption" and does NOT need an annual ERN filing. Apple's
         Encryption Documentation panel in App Store Connect accepts
         NO + no compliance code in this case.

         If we later bundle a third-party crypto library, link OpenSSL,
         add an end-to-end encrypted chat feature, or otherwise reach for
         encryption beyond Apple's standard surfaces, flip this back to
         YES and file the year-letter. The audit T27 cleanup that removed
         the contradictory ITSAppUsesNonExemptEncryption_NoCryptography_Exemption
         pairing applies regardless of which way this key flips. -->
    <key>ITSAppUsesNonExemptEncryption</key>
    <false/>

    <!-- Camera permission for the operator AVFoundation barcode scanner -->
    <key>NSCameraUsageDescription</key>
    <string>Thapsus uses your camera to scan parcel barcodes at the warehouse and capture proof-of-delivery photos on rider runs.</string>

    <!-- Photo library — POD photos and parcel-condition shots -->
    <key>NSPhotoLibraryUsageDescription</key>
    <string>Thapsus saves proof-of-delivery photos to your library so they remain with you alongside our records.</string>
    <key>NSPhotoLibraryAddUsageDescription</key>
    <string>Thapsus saves proof-of-delivery photos to your library so they remain with you alongside our records.</string>

    <!-- Contact Picker for the customer address book -->
    <key>NSContactsUsageDescription</key>
    <string>Thapsus uses your contacts so you can quickly assign a recipient to a parcel without retyping their phone number.</string>

    <!-- NSLocalNetworkUsageDescription removed 2026-05-17: the only printing
         path is AirPrint via UIPrintInteractionController in
         Hardware/LabelPrinter.swift, which is system-mediated and does not
         trigger the Local Network prompt. The previous declaration was
         over-declared per audit P1 #2 (docs/app_store_submission_plan_2026_05_16.md). -->
</dict>
</plist>
